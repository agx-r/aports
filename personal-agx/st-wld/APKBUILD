# Maintainer: agx <agxr@tuta.io>
pkgname=st-wld
_commit=c63a87cd936c1eeef14c4c21572e5b782d3df4bc
pkgver=0.7_git20161214
pkgrel=6
pkgdesc="st terminal ported to Wayland using wld"
url="https://github.com/michaelforney/st"
arch="all"
license="MIT"
depends="ncurses-terminfo-base font-liberation"
makedepends="fontconfig-dev freetype-dev wayland-dev wayland-protocols libxkbcommon-dev wld-dev pixman-dev"
subpackages="$pkgname-doc $pkgname-dbg"
source="st-$_commit.tar.gz::https://github.com/michaelforney/st/archive/$_commit.tar.gz
        0001-Port-to-wayland-using-wld.patch
        0002-Only-send-SIGHUP-on-close-when-using-PTY.patch
        0003-Add-support-for-plumbing-via-right-click.patch
        0004-Start-dmenu-on-bottom-for-ISO-14755-input.patch
        config.h"

provides="st-virtual"
provider_priority=100
builddir="$srcdir/st-$_commit"

prepare() {
  default_prepare
	cp "$srcdir"/config.h "$builddir"/config.h
  local proto_xml="/usr/share/wayland-protocols/stable/xdg-shell/xdg-shell.xml"
  sed -i "s|^XDG_SHELL_PROTO =.*|XDG_SHELL_PROTO = $proto_xml|" config.mk
  sed -i 's/xdg-shell-unstable-v5/xdg-shell/g' Makefile
  sed -i '/tic/d' Makefile
}

build() {
	make
}

package() {
	make DESTDIR="$pkgdir" PREFIX=/usr install
}

