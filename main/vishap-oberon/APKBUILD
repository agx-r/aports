# Maintainer: agx <agxr@tuta.io>

pkgname="vishap-oberon-compiler"
pkgver="2.1.2"
pkgrel=0
pkgdesc="Vishap Oberon Compiler (VOC) built with TCC"
url="https://github.com/vishapoberon/compiler"
arch="all"
license="GPL-3.0-or-later"
makedepends="build-base tcc"
source="$pkgname-$pkgver.tar.gz::https://github.com/vishapoberon/compiler/archive/refs/tags/v$pkgver.tar.gz"

builddir="$srcdir/compiler-$pkgver"

prepare() {
	default_prepare
	cd "$builddir"
	sed -i "s/git rev-parse --abbrev-ref HEAD/echo v$pkgver/g" makefile
}

build() {
	cd "$builddir"

	make -j1 full CC="tcc"
}

package() {
	cd "$builddir"

	mkdir -p "$pkgdir"/usr/bin
	mkdir -p "$pkgdir"/usr/lib/voc

	if [ -d "install" ]; then
		cp -r install/bin/* "$pkgdir"/usr/bin/
		cp -r install/lib/* "$pkgdir"/usr/lib/voc/
	else
		echo "ERROR: 'install' directory missing"
		return 1
	fi
}

sha512sums="
