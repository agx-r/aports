source="
	AyuGram-$pkgver.tar.gz::https://github.com/AyuGram/AyuGramDesktop/archive/refs/tags/v$pkgver.tar.gz
	td-$_tdlib_commit.tar.gz::https://github.com/tdlib/td/archive/$_tdlib_commit.tar.gz
	"

builddir="$srcdir/AyuGramDesktop-$pkgver"


_module_name() {
	local url="$1"
	local host filename name commit
	host=$(echo "$url" | cut -d/ -f3)
	name=$(echo "$url" | cut -d/ -f5)
	commit="${filename%%.*}"
	case "$host" in
		gitlab.com) echo "$commit" ;;
		*)          echo "$name-$commit" ;;
	esac
}

prepare() {
	cd "$builddir"

	_fill_modules() {
		local dir="${1:-.}"
		find "$dir" -type f -name .gitmodules | while read -r gitmodules; do
			local prefix
			prefix="$(dirname "$gitmodules")"
			[ "$prefix" = "." ] && prefix="" || prefix="$prefix/"
			grep path "$gitmodules" | awk '{print $3}' | while read -r p; do
				p="${p%$'\r'}"
				[ -z "$p" ] && continue
				local target="$prefix$p"
				local basename
				basename="$(basename "$target")"
				local found
				found="$(find "$srcdir" -maxdepth 1 -type d -name "${basename}-*" | head -n1)"
				if [ -n "$found" ]; then
					echo "Filling $target with $found"
					cp -r "$found/." "$target"
					_fill_modules "$target"
				else
					echo "WARNING: submodule dir not found for $target (basename=$basename)"
				fi
			done
		done
	}
	_fill_modules

	sed -i 's/find_package(protobuf REQUIRED)/find_package(protobuf REQUIRED CONFIG)/' \
		Telegram/ThirdParty/cld3/CMakeLists.txt
}

build() {
	LDFLAGS="$LDFLAGS -Wl,-z,stack-size=1024768"

	cmake -S "$srcdir/td-$_tdlib_commit" \
	      -B "$srcdir/td-$_tdlib_commit/build" \
	      -DCMAKE_BUILD_TYPE=None \
	      -DCMAKE_INSTALL_PREFIX="$srcdir/td-$_tdlib_commit/install" \
	      -Wno-dev \
	      -DTD_E2E_ONLY=ON
	cmake --build "$srcdir/td-$_tdlib_commit/build"
	cmake --install "$srcdir/td-$_tdlib_commit/build"

	cmake -B build -G Ninja "$builddir" \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DTDESKTOP_API_ID="${MAKEPKG_AYUGRAM_API_ID:-2040}" \
		-DTDESKTOP_API_HASH="${MAKEPKG_AYUGRAM_API_HASH:-b18441a1ff607e10a989891a5462e627}" \
		-DDESKTOP_APP_DISABLE_AUTOUPDATE=ON \
		-DDESKTOP_APP_DISABLE_CRASH_REPORTS=ON \
		-DDESKTOP_APP_USE_PACKAGED=ON \
		-Dtde2e_DIR="$srcdir/td-$_tdlib_commit/install/lib/cmake/tde2e"
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

sha512sums="
SKIP  AyuGram-$pkgver.tar.gz
SKIP  td-$_tdlib_commit.tar.gz
"
