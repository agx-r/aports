d0b4d0b2724ed1ba898703f957fc95e1f345c8bd880fa4bf991df49a4a670f7f817fd21efc9c5717c57e4d1f0a58c67673ec17c4daf365a017b4b1a025a0fa7f  0001-Port-to-wayland-using-wld.patch
"
