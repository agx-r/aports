# Maintainer: agx <agxr@tuta.io>
pkgname="xray-core"
pkgver="26.2.6"
pkgrel=0
pkgdesc="Xray-core"
url="https://github.com/xtls/xray-core"
arch="all"
license="MPL-2.0"
makedepends="go"
options="net !strip"
source="$pkgname-$pkgver.tar.gz::https://github.com/xtls/xray-core/archive/v$pkgver.tar.gz
			  0001-security-implement-Landlock-fail-closed-sandbox.patch"
builddir="$srcdir/Xray-core-$pkgver"
	prepare() {
	default_prepare
	go get github.com/landlock-lsm/go-landlock/landlock
	go mod tidy
}
build() {
	export CGO_ENABLED=0
	export GOCACHE="$srcdir/go-cache"
	export GOPATH="$srcdir/go"
	export GO111MODULE=on
	local _ldflags="-X github.com/xtls/xray-core/core.build=v$pkgver -s -w -buildid="
	local _gcflags="all=-l=4"
	go build -v -o xray-bin \
		-buildmode=exe \
		-trimpath \
		-buildvcs=false \
		-gcflags="$_gcflags" \
		-ldflags="$_ldflags" \
		./main
}
package() {
	install -Dm755 xray-bin "$pkgdir/usr/bin/xray"
}

