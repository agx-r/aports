f821dcbd7054663d03491229e88d2548453678606d9ed0ebeb0024327cebf0b78a4aaf350afe4b752dd2e3143c66a0bc4b73ee8cd50df73ad2a197200c718c6f  0001-security-implement-Landlock-fail-closed-sandbox.patch
"
